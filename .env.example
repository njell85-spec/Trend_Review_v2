# PubMed
PUBMED_EMAIL=your-email@example.com
PUBMED_API_KEY=

# LLM provider.
# Supported: claude-code, gemini, openai, anthropic, none
# claude-code uses a Claude Code subscription session/OAuth token instead of Anthropic API billing.
LLM_PROVIDER=claude-code
CLAUDE_CODE_OAUTH_TOKEN=
CLAUDE_CODE_MODEL=opus
CLAUDE_CODE_TIMEOUT_MS=600000
GEMINI_API_KEY=
GEMINI_MODEL=
OPENAI_API_KEY=
OPENAI_MODEL=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=

# Delivery
DASHBOARD_URL=https://your-user.github.io/your-repo/
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Kakao REST API delivery
# KAKAO_REST_API_KEY is the Kakao Developers REST API key.
# KAKAO_CLIENT_SECRET is needed only when Client Secret is enabled for the Kakao app.
# KAKAO_REFRESH_TOKEN is recommended for scheduled runs.
# KAKAO_ACCESS_TOKEN is optional for one-off local tests and expires quickly.
KAKAO_REST_API_KEY=
KAKAO_CLIENT_SECRET=
KAKAO_REFRESH_TOKEN=
KAKAO_ACCESS_TOKEN=
